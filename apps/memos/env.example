# memos — copied to host-only secrets/memos.env by scripts/install.sh;
# sso-setup.sh creates the break-glass host (named after your Pocket ID
# username, so the passkey lands on the same account) and mints the client.
MEMOS_OIDC_CLIENT_ID=
MEMOS_OIDC_CLIENT_SECRET=
MEMOS_ADMIN_USER=
MEMOS_ADMIN_PASSWORD=
MEMOS_ADMIN_TOKEN=               # optional: a minted access token also seeds the IdP
