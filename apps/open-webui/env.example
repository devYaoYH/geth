# open-webui — copied to host-only secrets/open-webui.env by scripts/install.sh;
# minted by scripts/sso-setup.sh. The assistant's LLM key is NOT here — it is
# a tenant credential and stays in the node-level .env (the caller declares).
OPENWEBUI_OIDC_CLIENT_ID=
OPENWEBUI_OIDC_CLIENT_SECRET=
OPENWEBUI_SECRET_KEY=            # session-JWT signing key; generated by sso-setup.sh —
                                 # without it, every recreate logs everyone out

