# search-broker — copied to host-only secrets/search-broker.env by install.sh.
# EXA_API_KEY is held only by search-egress. It never enters the agent network.
EXA_API_KEY=
# Shared only by search-broker and search-egress; generate with openssl rand -hex 32.
SEARCH_EGRESS_TOKEN=
# Dedicated Postgres roles: owner initializes schema; broker writes; dashboard reads.
SEARCH_AUDIT_DB_OWNER_PASSWORD=
SEARCH_AUDIT_DB_WRITER_PASSWORD=
SEARCH_AUDIT_DB_READER_PASSWORD=
# Legacy JSONL import defaults to a dry run; set false for the one-time import.
SEARCH_AUDIT_MIGRATE_DRY_RUN=true
