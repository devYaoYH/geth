# search-broker — copied to host-only secrets/search-broker.env by install.sh.
# EXA_API_KEY is held only by search-egress. It never enters the agent network.
# require: an Exa API key (https://exa.ai) — search stays down until this is set
EXA_API_KEY=
# Shared only by search-broker and search-egress; generate with openssl rand -hex 32.
# mint:rand-hex-32
SEARCH_EGRESS_TOKEN=
# Dedicated Postgres roles: owner initializes schema; broker writes; dashboard reads.
# mint:rand-hex-32
SEARCH_AUDIT_DB_OWNER_PASSWORD=
# mint:rand-hex-32
SEARCH_AUDIT_DB_WRITER_PASSWORD=
# mint:rand-hex-32
SEARCH_AUDIT_DB_READER_PASSWORD=
# Chat toolshim authenticates to the broker with a separate credential so the
# audit trail distinguishes chat searches from agent-dev searches, and the
# capabilities can be revoked independently. Minted by chat-tools-setup.sh.
# mint:rand-hex-32
CHAT_SEARCH_TOKEN=
# The audit identity used when a request is authenticated with CHAT_SEARCH_TOKEN.
# The broker uses this to tag audit rows so chat searches are distinguishable
# from agent-dev searches in the audit log. The shim never reads this.
# default:chat
CHAT_SEARCH_CAPABILITY_ID=chat
# Legacy JSONL import defaults to a dry run; set false for the one-time import.
SEARCH_AUDIT_MIGRATE_DRY_RUN=true
