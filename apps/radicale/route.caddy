# radicale's door — imported by the root Caddyfile (import apps/*/route.caddy),
# so ring guards and the (authed) snippet are already defined when this loads.
# Ring 1 — calendar/contacts (enable with:  docker compose --profile apps up -d)
# The browser door (Radicale's web UI) authenticates via the authshim ->
# Pocket ID. DAV paths stay on the ring guard: CalDAV clients speak Basic
# auth, not OIDC redirects — their credential plane is the app's business,
# same split as LiteLLM (humans via SSO, API callers via their own keys).
cal.{$NODE_DOMAIN} {
	import ring1
	handle /oauth2/* {
		reverse_proxy oauth2-proxy:4180
	}
	@webui path / /.web /.web/*
	handle @webui {
		import authed
		# Inject the Basic auth header so Radicale's htpasswd check passes
		# without a second login form. The value is base64 of
		# "operator:<RADICALE_TOOL_PASSWORD>" (minted host-side into
		# secrets/radicale.env). Every SSO-authed human acts as "operator"
		# on the web UI — acceptable on today's single-user node.
		reverse_proxy radicale:5232 {
			header_up Authorization "Basic {env.RADICALE_WEB_AUTH}"
		}
	}
	handle {
		reverse_proxy radicale:5232
	}
}
