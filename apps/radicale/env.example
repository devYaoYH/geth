# radicale — holds no credentials today: the door (authshim) is the auth for
# the web UI, DAV clients ride the ring guard. File exists so the compose
# include's env_file resolves.
RADICALE_TOOL_USER=operator    # Basic-auth user for chat shim (created by chat-tools-setup.sh)
RADICALE_TOOL_PASSWORD=          # generated on first run; value lives in secrets/radicale.env
RADICALE_TOOL_CAL_PATH=/operator/calendar   # CalDAV collection (no trailing slash)
