[server]
hosts = 0.0.0.0:5232

[auth]
# Basic-auth via htpasswd; credentials live in /data/users (minted host-side)
# htpasswd_encryption=md5 matches `openssl passwd -apr1` used by chat-tools-setup.sh
# (Apache MD5, aka apr1)
type = htpasswd
htpasswd_filename = /data/users
htpasswd_encryption = md5

[storage]
# Filesystem-backed collections live under /data (volume-owned state)
filesystem_folder = /data/collections

[web]
# Lightweight built-in HTML UI on / ("internal" is the module name)
type = internal
# Tells Radicale's LoginScene to send the SSO cookie (credentials: omit is
# the default, which strips it -> the form appears). With prefer_browser_login
# the browser's auto-login probe carries the SSO session cookie forward,
# allowing Caddy's injected Basic credential to authenticate seamlessly.
prefer_browser_login = true

[rights]
# Enforce per-user ownership; rules file minted/owned at /data/rights
# by chat-tools-setup.sh
type = from_file
file = /data/rights

[logging]
level = info
