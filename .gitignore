# The skill-discovery symlink IS tracked (global gitignores often exclude
# .claude); everything else under .claude (session state, local settings)
# stays out. The library itself lives in skills/ — framework-agnostic.
!.claude/
.claude/*
!.claude/skills

# Host-only per-app secrets (see docs/SSO.md); node-level keys stay in .env
secrets/
