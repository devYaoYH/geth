# Copy to .env — NEVER commit .env to git.
# Generate secrets with:  openssl rand -hex 32

# Identity
NODE_DOMAIN=example.com          # you own this at a registrar; DNS is yours
ACME_EMAIL=you@example.com       # Let's Encrypt expiry notices

# Extra CIDRs the ring guards trust besides RFC1918 + CGNAT (optional).
# e.g. a LAN that hands out non-private addresses. Comma-free, space-separated.
EXTRA_TRUSTED_RANGES=

# LiteLLM (ring 0 — crown jewels)
LITELLM_MASTER_KEY=sk-CHANGE-ME          # admin key; agents NEVER see this
LITELLM_SALT_KEY=CHANGE-ME               # encrypts stored provider keys; set once
LITELLM_DB_PASSWORD=CHANGE-ME

# Upstream model providers (only what you use; leave others empty)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Identity plane — Pocket ID needs NO secrets here (keys live in its volume).
# POCKET_ID_API_KEY: mint in Pocket ID admin -> API Keys; used by scripts/invite.sh
POCKET_ID_API_KEY=

# SSO clients — minted automatically by scripts/sso-setup.sh:
FORGEJO_OIDC_CLIENT_ID=
FORGEJO_OIDC_CLIENT_SECRET=
LITELLM_OIDC_CLIENT_ID=
LITELLM_OIDC_CLIENT_SECRET=
LITELLM_PROXY_ADMIN_ID=       # Pocket ID user id granted LiteLLM UI admin

# Forward-auth shim (only if the authshim profile is enabled; client created
# in Pocket ID admin first — see docs/ONBOARDING.md)
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=              # openssl rand -base64 32 | head -c 32

# Forgejo API token for scripts/mirror.sh (create under
# user settings -> Applications, scopes: read/write repository)
FORGEJO_TOKEN=

# The resident dev-agent (docs/AGENT.md) — both are MINTED credentials:
AGENT_LLM_KEY=            # LiteLLM virtual key: /key/generate, budgeted, model-allowlisted
AGENT_FORGEJO_TOKEN=      # Forgejo token for user agent-dev: repo + issue scope only
NODE_CONFIG_REPO=         # e.g. yourname/node-config (path inside Forgejo)
COORDINATION_REPO=        # the agents' shared notebook; bootstrap-forgejo.sh writes this

# The front-door assistant (agent/ASSISTANT.md) — the tenant YOU talk to:
ASSISTANT_LLM_KEY=        # its own LiteLLM virtual key: /key/generate, budgeted
ASSISTANT_FORGEJO_TOKEN=  # minted by bootstrap-forgejo.sh: read:repository,write:issue
ASSISTANT_MODEL=claude-sonnet   # conversation deserves the better model; budget caps it

# Feeds (--profile feeds): Miniflux + its own Postgres
MINIFLUX_DB_PASSWORD=
MINIFLUX_ADMIN_USER=admin        # break-glass; day-to-day login is your passkey (OIDC)
MINIFLUX_ADMIN_PASSWORD=
MINIFLUX_OIDC_CLIENT_ID=         # minted by scripts/sso-setup.sh
MINIFLUX_OIDC_CLIENT_SECRET=
MINIFLUX_TASK_TOKEN=             # READ-ONLY API token for the digester: mint in
                                 # Miniflux -> Settings -> API keys; declared in
                                 # tasks/morning-digest.md's env: list

# Google bridge (--profile bridge): image is operator-mirrored + digest-pinned
GOG_BRIDGE_IMAGE=                # e.g. forgejo.internal/mirrors/gog-bridge@sha256:...
GOG_OAUTH_CLIENT_ID=             # cold-upstream class: touched at setup only
GOG_OAUTH_CLIENT_SECRET=

# Notes
# - Agents get VIRTUAL keys minted via the LiteLLM UI/API, each with its own
#   budget and model allowlist. Provider keys live only in this file and inside
#   LiteLLM's encrypted store.
# - When the secrets-box tier (Tier 2) lands, this file's contents move to the
#   vault device and are injected at runtime instead of living on disk here.
