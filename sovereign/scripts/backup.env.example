# Copy to scripts/backup.env — NEVER commit backup.env.
# Backblaze B2 example (any restic backend works: S3, SFTP, rest-server, local NAS)

export RESTIC_REPOSITORY="b2:your-bucket-name:sovereign-node"
export RESTIC_PASSWORD="CHANGE-ME-long-random-passphrase"   # losing this = losing backups
export B2_ACCOUNT_ID="CHANGE-ME"
export B2_ACCOUNT_KEY="CHANGE-ME"

# Write RESTIC_PASSWORD down somewhere physical, off this machine.
# The failure mode "house lost the box AND the passphrase was on the box"
# is the one this line exists to prevent.
