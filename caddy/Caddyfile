# The front door. Every route is annotated with its trust ring.
# Ring 0 = you only (admin) · Ring 1 = trusted people · Ring 2 = public internet.
#
# MVP enforcement is coarse (IP-based + app-level auth). The policy engine that
# replaces these snippets with identity-aware, agent-drafted / human-approved
# rules is milestone M2 in docs/ROADMAP.md.

{
	email {$ACME_EMAIL}
}

# --- reusable guards ---------------------------------------------------------

# EXTRA_TRUSTED_RANGES (.env, optional): additional CIDRs your deployment
# trusts — e.g. a LAN that hands out non-RFC1918 addresses. Defaults to
# TEST-NET-1, which matches nothing real.
(ring0) {
	# Admin surfaces: LAN / VPN / tunnel only.
	@outside not remote_ip private_ranges 100.64.0.0/10 {$EXTRA_TRUSTED_RANGES:192.0.2.0/32}
	respond @outside "closed door" 403
}

(ring1) {
	# Trusted-people surfaces: same network guard for the MVP; the apps behind
	# these routes ALSO have their own logins (Forgejo, Radicale). Defense in
	# depth until the identity-aware proxy lands.
	@outside not remote_ip private_ranges 100.64.0.0/10 {$EXTRA_TRUSTED_RANGES:192.0.2.0/32}
	respond @outside "closed door" 403
}

# Forward-auth for apps with no native OIDC: Caddy asks oauth2-proxy (an OIDC
# client of Pocket ID); a hit continues with identity headers copied, a miss
# bounces the browser into the sign-in flow — one passkey at the door. Shimmed
# routes must ALSO proxy /oauth2/* to oauth2-proxy (see cal below). The shim
# runs under the authshim profile; sso-setup.sh mints its client and starts it.
(authed) {
	forward_auth oauth2-proxy:4180 {
		uri /oauth2/auth
		copy_headers X-Auth-Request-User X-Auth-Request-Email
		@unauthed status 401 403
		handle_response @unauthed {
			redir * /oauth2/start?rd={scheme}://{host}{uri}
		}
	}
}

# --- routes -------------------------------------------------------------------

# Ring 1 — git platform (Forgejo has its own auth; registration disabled)
git.{$NODE_DOMAIN} {
	import ring1
	reverse_proxy forgejo:3000
}

# Ring 0 — LLM gateway. The /ui admin and the API are for you and, later, for
# agents holding virtual keys. Never ring 2.
llm.{$NODE_DOMAIN} {
	import ring0
	reverse_proxy litellm:4000
}

# Ring 2 (by function) — the identity provider IS the public door: family logs
# in from anywhere with a passkey, so the login flow cannot sit behind an IP
# guard. Pocket ID is passkey-only by construction; its admin surface is
# protected by the operator's passkey.
auth.{$NODE_DOMAIN} {
	reverse_proxy pocket-id:1411
}

# Ring 1 — trusted-people dashboard (status + links; config lives in git)
home.{$NODE_DOMAIN} {
	import ring1
	reverse_proxy homepage:3000
}

# Ring 0 — service registry: what exists on this node and what can it call.
# Discovery/audit only; agents read it directly on the spur (registry:8090).
registry.{$NODE_DOMAIN} {
	import ring0
	reverse_proxy registry:8090
}

# --- app doors ---------------------------------------------------------------
# Each app fragment ships its own route: apps/<name>/route.caddy (mounted at
# /srv/apps). Snippets above (ring0/ring1/authed) are in scope for them.
import /srv/apps/*/route.caddy

# Ring 1 — the apex lands on the dashboard. If the apex ever goes public
# (ring 2 below), move this redirect to a path or drop it deliberately.
{$NODE_DOMAIN} {
	import ring1
	redir https://home.{$NODE_DOMAIN}{uri}
}

# Ring 2 — the deliberately public surface. Empty by design in the MVP.
# When you're ready: a busy-only calendar feed, a blog, a booking page.
# Every line added here is attack surface; add slowly, remove eagerly.
#
# {$NODE_DOMAIN} {
# 	respond "hello from a sovereign node" 200
# }

# --- local-only layer -------------------------------------------------------
# Operator-specific routes live in local/*.caddy — NOT tracked in git (this
# repo is a public template; your node's particulars stay on your node).
# Anything generic enough for every deployment belongs above instead.
import local/*.caddy
